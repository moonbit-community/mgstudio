pub impl[T : @core.Message] SystemParam for @core.MessageWriter[T]
pub impl[E : @ecs.ComponentObserverEvent, C : @ecs.Component] SystemParam for @ecs.ComponentOn[E, C]
pub impl[T : @ecs.Message] SystemParam for @ecs.MessageMutator[T]
pub impl[T : @ecs.Message] SystemParam for @ecs.MessageReader[T]
pub impl[T : @ecs.Message] SystemParam for @ecs.MessageWriter[T]
pub impl[E : @ecs.TriggerEvent] SystemParam for @ecs.On[E]
pub impl[D : @ecs.QueryData, F : FromWorld + @ecs.QueryFilter] SystemParam for @ecs.Query[D, F]
pub impl[T : @ecs.Component] SystemParam for @ecs.RemovedComponents[T]

