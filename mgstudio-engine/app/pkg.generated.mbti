pub struct SystemAccess {
  query_accesses : Array[QuerySystemAccess]
  read_resource_ids : Array[Int]
  write_resource_ids : Array[Int]
  mut is_exclusive : Bool
  mut uses_deferred_commands : Bool
  mut validation_error : String?
}
pub fn SystemAccess::add_query_access(Self, @ecs.QueryDataAccess, @ecs.QueryFilterAccess) -> Unit
pub fn SystemAccess::add_read_resource(Self, Int) -> Unit
pub fn SystemAccess::add_write_resource(Self, Int) -> Unit
pub fn SystemAccess::exclusive() -> Self
pub fn SystemAccess::is_exclusive(Self) -> Bool
pub fn SystemAccess::mark_deferred_commands(Self) -> Unit
pub fn SystemAccess::new() -> Self
pub fn SystemAccess::uses_deferred_commands(Self) -> Bool
pub fn SystemAccess::validation_error(Self) -> String?

pub struct SystemConfig[W] {
  system : (W) -> Unit
  name : String?
  debug_name : String?
  error_handler : ((Error, ErrorContext) -> Unit)?
  run_ifs : Array[(W, @ref.Ref[Json]) -> Bool]
  run_if_states : Array[@ref.Ref[Json]]
  chain_members : Array[SystemConfig[W]]?
  chain_ignore_deferred : Bool
  set : String?
  member_sets : Array[String]
  before : Array[String]
  after : Array[String]
  before_ignore_deferred : Array[String]
  after_ignore_deferred : Array[String]
  is_apply_deferred_node : Bool
  run_if_last_run_sequences : Array[Int]
  mut last_run_sequence : Int
  mut access_factory : ((@ecs.World) -> SystemAccess)?
}
pub fn[W] SystemConfig::after(Self[W], String) -> Self[W]
pub fn[W] SystemConfig::after_ignore_deferred(Self[W], String) -> Self[W]
pub fn[W] SystemConfig::before(Self[W], String) -> Self[W]
pub fn[W] SystemConfig::before_ignore_deferred(Self[W], String) -> Self[W]
pub fn[W] SystemConfig::chain_ignore_deferred(Self[W]) -> Self[W]
pub fn[W] SystemConfig::handle_error_with(Self[W], (Error, ErrorContext) -> Unit) -> Self[W]
pub fn[W] SystemConfig::in_set(Self[W], String) -> Self[W]
pub fn[W] SystemConfig::named(Self[W], String) -> Self[W]
pub fn[W] SystemConfig::run_if(Self[W], (W) -> Bool) -> Self[W]
pub fn[M] SystemConfig::run_if_on_message(Self[@ecs.World], @ecs.MessageKey[M]) -> Self[@ecs.World]
pub fn[W] SystemConfig::run_if_stateful(Self[W], Json, (W, @ref.Ref[Json]) -> Bool) -> Self[W]

