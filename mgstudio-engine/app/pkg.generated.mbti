pub type LogLayer = (LogRecord) -> Unit

pub type RenderErrorHandler = (RenderRuntimeError) -> RenderErrorPolicy

pub type RunConditionFn[W] = (W) -> Bool

pub type RunnerBuilder[W] = (App[W]) -> () -> Unit

pub type RunnerFn = () -> Unit

pub type StatefulRunConditionFn[W] = (W, @ref.Ref[Json]) -> Bool

pub type SubAppExtractFn[W] = (W, W) -> (W, W)

pub type SystemFn[W] = (W) -> Unit

pub type SystemSet = String

pub type TimelineTraceSpanSink = (TimelineTraceSpan) -> Unit

