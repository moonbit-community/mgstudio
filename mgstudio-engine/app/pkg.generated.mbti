pub(open) trait FreelyMutableState : States {
}

pub(open) trait FromWorld {
  from_world(@ecs.World) -> Self
}
pub impl FromWorld for Bool
pub impl FromWorld for Int
pub impl FromWorld for Float
pub impl FromWorld for String
pub impl[T : @ecs.Component] FromWorld for @ecs.Added[T]
pub impl FromWorld for @ecs.All
pub impl[T : @ecs.Component] FromWorld for @ecs.Allow[T]
pub impl[T : @ecs.Component] FromWorld for @ecs.Changed[T]
pub impl[T : @ecs.Component] FromWorld for @ecs.Has[T]
pub impl[T] FromWorld for @ecs.MessageCursor[T]
pub impl[T : @ecs.Component] FromWorld for @ecs.Optional[T]
pub impl[F : FromWorld] FromWorld for @ecs.Or[F]
pub impl[T : @ecs.Component] FromWorld for @ecs.With[T]
pub impl[T : @ecs.Component] FromWorld for @ecs.Without[T]
pub impl[T] FromWorld for Array[T]
pub impl[A : FromWorld, B : FromWorld] FromWorld for (A, B)
pub impl[A : FromWorld, B : FromWorld, C : FromWorld] FromWorld for (A, B, C)

pub(open) trait Plugin {
  build(Self, App[@ecs.World]) -> App[@ecs.World]
  name(Self) -> String = _
  is_unique(Self) -> Bool = _
  ready(Self, App[@ecs.World]) -> Bool = _
  finish(Self, App[@ecs.World]) -> App[@ecs.World] = _
  cleanup(Self, App[@ecs.World]) -> App[@ecs.World] = _
}

pub(open) trait PluginGroup {
  build(Self) -> PluginGroupBuilder[@ecs.World]
  name(Self) -> String = _
}

pub(open) trait PointerObserverKind {
  event_kind() -> @pointer_events.PointerEventKind
  source_label() -> String
}

pub(open) trait Resource {
  resource() -> @ecs.ResourceKey[Self]
}
pub impl[T : @ecs.Message] Resource for @ecs.Messages[T]

pub(open) trait States : Eq + @debug.Debug {
  debug_name(Self) -> String
  dependency_depth(Self) -> Int = _
}

pub(open) trait SubStates : States + FreelyMutableState {
}

pub(open) trait SystemParam {
  init_state(@ecs.World) -> Json
  get(@ref.Ref[Json]) -> Self raise
  store(Self, @ref.Ref[Json]) -> Unit
  access(@ecs.World) -> SystemAccess = _
}
