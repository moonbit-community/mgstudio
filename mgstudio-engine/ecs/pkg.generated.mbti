pub fn RequiredComponents::len(Self) -> Int

type RequiredComponentsState

pub struct ResourceAccess[T] {
  world : World
  key : ResourceKey[T]
}
pub fn[T] ResourceAccess::get(Self[T]) -> T?
pub fn[T] ResourceAccess::insert(Self[T], T, Int) -> Unit
pub fn[T] ResourceAccess::is_present(Self[T]) -> Bool
pub fn[T] ResourceAccess::remove(Self[T]) -> T?
pub fn[T] ResourceAccess::set(Self[T], T, Int) -> Bool
pub fn[T] ResourceAccess::ticks(Self[T]) -> @core.ComponentTicks?
pub fn[T] ResourceAccess::update(Self[T], Int, (T) -> T) -> Bool
pub fn[T] ResourceAccess::upsert(Self[T], T, Int) -> Unit

pub struct ResourceKey[T] {
  id : Int
  debug_name : String
  marker : T?
}
pub fn[U, T] ResourceKey::cast(Self[T]) -> Self[U]
pub fn[T] ResourceKey::debug_name(Self[T]) -> String
pub fn[T] ResourceKey::id(Self[T]) -> Int

type ResourceSlot

pub struct With[T] {
  key : ComponentKey[T]
}
pub fn[T] With::new(ComponentKey[T]) -> Self[T]
pub impl[T] QueryFilter for With[T]

pub struct Without[T] {
  key : ComponentKey[T]
}
pub fn[T] Without::new(ComponentKey[T]) -> Self[T]
pub impl[T] QueryFilter for Without[T]

pub struct World {
  world_id : Int
  entities : @core.Entities
  mut change_tick : Int
  mut system_context : @core.SystemContext
  component_columns : Map[Int, Ref[@core.ComponentStore[ErasedValue]]]
  required_components : Map[Int, Ref[RequiredComponentsState]]
  used_components : Map[Int, Bool]
  removed_components : Map[Int, Ref[@core.Messages[@core.Entity]]]
  resources : Map[Int, ResourceSlot]
  mut previous_events : Map[Int, Array[ErasedValue]]
  current_events : Map[Int, Array[ErasedValue]]
}
pub fn[C : Component] World::add_observer(Self, (On[Insert, C]) -> Unit) -> ObserverHandle
pub fn World::advance_event_frame(Self) -> Unit
pub fn[T] World::clear_events(Self, EventKey[T]) -> Unit
pub fn[T] World::clear_messages(Self, MessageKey[T]) -> Unit
pub fn[T] World::component(Self, ComponentKey[T]) -> ComponentAccess[T]
pub fn[T : Component] World::component_typed(Self) -> ComponentAccess[T]
pub fn[T] World::contains_message(Self, MessageKey[T]) -> Bool
pub fn World::despawn(Self, @core.Entity) -> Unit raise EcsError
pub fn World::entity_count(Self) -> Int
pub fn[T] World::get(Self, @core.Entity, ComponentKey[T]) -> T? raise EcsError
pub fn[T : Component] World::get_component(Self, @core.Entity) -> T? raise EcsError
pub fn[T : Component] World::get_component_ref(Self, @core.Entity) -> ComponentRef[T]? raise EcsError
pub fn[A] World::get_ref(Self, @core.Entity, ComponentKey[A]) -> ComponentRef[A]? raise EcsError
pub fn[T] World::get_required_components(Self, ComponentKey[T]) -> RequiredComponents?
pub fn World::get_required_components_by_id(Self, Int) -> RequiredComponents?
pub fn[T] World::get_resource(Self, ResourceKey[T]) -> T? raise EcsError
pub fn[T] World::get_resource_ref(Self, ResourceKey[T]) -> Ref[T]? raise EcsError
pub fn[T] World::get_resource_ref_mut(Self, ResourceKey[T], Int) -> Ref[T]? raise EcsError
pub fn[T] World::get_resource_ticks(Self, ResourceKey[T]) -> @core.ComponentTicks?
pub fn World::get_system_context(Self) -> @core.SystemContext
pub fn World::increment_change_tick(Self) -> Int
pub fn[T] World::init_message(Self, MessageKey[T]) -> Unit
pub fn[T] World::insert_resource(Self, ResourceKey[T], T) -> Unit
pub fn[T] World::insert_resource_with_change_tick(Self, ResourceKey[T], T, Int) -> Unit
pub fn World::is_alive(Self, @core.Entity) -> Bool
pub fn[T] World::message_reader(Self, MessageKey[T], Ref[Int]) -> MessageReader[T]
pub fn[T] World::message_writer(Self, MessageKey[T]) -> MessageWriter[T]
pub fn World::new() -> Self
pub fn[A] World::query1(Self, ComponentKey[A]) -> Query1[A]
pub fn[A, F] World::query1_filtered(Self, ComponentKey[A], F) -> Query1Filtered[A, F]
pub fn[T : Component] World::query1_typed(Self) -> Query1[T]
pub fn[T : Component, F] World::query1_typed_filtered(Self, F) -> Query1Filtered[T, F]
pub fn[A, B] World::query2(Self, ComponentKey[A], ComponentKey[B]) -> Query2[A, B]
pub fn[A, B, F] World::query2_filtered(Self, ComponentKey[A], ComponentKey[B], F) -> Query2Filtered[A, B, F]
pub fn[A, B, F] World::query2_ref_mut_filtered(Self, ComponentKey[A], ComponentKey[B], F) -> Query2RefMutFiltered[A, B, F]
pub fn[A, B, F] World::query2_value_mut_filtered(Self, ComponentKey[A], ComponentKey[B], F) -> Query2ValueMutFiltered[A, B, F]
pub fn[A, B, C] World::query3(Self, ComponentKey[A], ComponentKey[B], ComponentKey[C]) -> Query3[A, B, C]
pub fn[A, B, C, F] World::query3_filtered(Self, ComponentKey[A], ComponentKey[B], ComponentKey[C], F) -> Query3Filtered[A, B, C, F]
pub fn[A, B, C, F] World::query3_ref_mut_optional_filtered(Self, ComponentKey[A], ComponentKey[B], ComponentKey[C], F) -> Query3RefMutOptionalFiltered[A, B, C, F]
pub fn[A, B, C, F] World::query3_value_ref_mut_filtered(Self, ComponentKey[A], ComponentKey[B], ComponentKey[C], F) -> Query3ValueRefMutFiltered[A, B, C, F]
pub fn[F] World::query_entities_filtered(Self, F) -> EntityQuery[F]
pub fn World::read_change_tick(Self) -> Int
pub fn[T] World::read_events(Self, EventKey[T]) -> Array[T] raise EcsError
