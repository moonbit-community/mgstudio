import {
  "Milky2018/mgstudio/ecs" @ecs,
  "moonbitlang/core/json",
  "Milky2018/moon_wgsl" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_motion_blur_wgsl_source",
      "input": "motion_blur.wgsl",
      "output": "embedded_wgsl_motion_blur_wgsl.mbt",
    },
  ],
)
