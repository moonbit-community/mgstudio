import {
  "Milky2018/mgstudio/ecs" @ecs,
  "Milky2018/mgstudio/post_process" @post_process,
  "moonbitlang/core/json",
  "Milky2018/moon_wgsl" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_bloom_wgsl_source",
      "input": "bloom.wgsl",
      "output": "embedded_wgsl_bloom_wgsl.mbt",
    },
  ],
)
