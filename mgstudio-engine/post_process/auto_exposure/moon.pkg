import {
  "Milky2018/mgstudio/pbr" @pbr,
  "moonbitlang/core/json",
  "Milky2018/mgstudio/naga_oil" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_auto_exposure_wgsl_source",
      "input": "auto_exposure.wgsl",
      "output": "embedded_wgsl_auto_exposure_wgsl.mbt",
    },
  ],
)
