import {
  "Milky2018/mgstudio/app",
  "Milky2018/mgstudio/core",
  "Milky2018/mgstudio/core_pipeline",
  "Milky2018/mgstudio/ecs",
  "Milky2018/moon_wgsl" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_deferred_lighting_wgsl_source",
      "input": "deferred_lighting.wgsl",
      "output": "embedded_wgsl_deferred_lighting_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_pbr_deferred_functions_wgsl_source",
      "input": "pbr_deferred_functions.wgsl",
      "output": "embedded_wgsl_pbr_deferred_functions_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_pbr_deferred_types_wgsl_source",
      "input": "pbr_deferred_types.wgsl",
      "output": "embedded_wgsl_pbr_deferred_types_wgsl.mbt",
    },
  ],
)
