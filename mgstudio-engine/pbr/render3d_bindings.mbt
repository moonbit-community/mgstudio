///|
fn render3d_begin_pass_3d(
  target_id~ : Int,
  target_layer? : Int = -1,
  secondary_target_id? : Int = -1,
  width~ : Int,
  height~ : Int,
  clear_r~ : Float,
  clear_g~ : Float,
  clear_b~ : Float,
  clear_a~ : Float,
  camera_transform : @transform.Transform,
  pass_projection : Render3dPassProjection,
  viewport_x~ : Int,
  viewport_y~ : Int,
  viewport_width~ : Int,
  viewport_height~ : Int,
  lighting : Render3dLightingState,
  camera_exposure? : Float = 1.0F,
  previous_clip_from_world~ : ProjectionMatrix3d?,
  transmission_blur_taps? : Float = 0.0F,
  transmission_steps? : Float = 0.0F,
  point_shadow_texture_id? : Int = -1,
  point_shadow_enabled? : Float = 0.0F,
  point_shadow_depth_bias? : Float = 0.0F,
  transmission_source_texture_id? : Int = -1,
  environment_diffuse_texture_id? : Int = -1,
  environment_specular_texture_id? : Int = -1,
  environment_map_intensity? : Float = 0.0F,
  environment_map_rotation? : @math.Quat = @math.Quat::identity(),
  point_shadow_near~ : Float,
  pass_kind~ : Int,
  clear_enabled~ : Int,
) -> Unit {
  @pbr_render.render3d_begin_pass_3d(
    target_id~,
    target_layer~,
    secondary_target_id~,
    width~,
    height~,
    clear_r~,
    clear_g~,
    clear_b~,
    clear_a~,
    camera_transform,
    pass_projection,
    viewport_x~,
    viewport_y~,
    viewport_width~,
    viewport_height~,
    lighting,
    camera_exposure~,
    previous_clip_from_world~,
    transmission_blur_taps~,
    transmission_steps~,
    point_shadow_texture_id~,
    point_shadow_enabled~,
    point_shadow_depth_bias~,
    transmission_source_texture_id~,
    environment_diffuse_texture_id~,
    environment_specular_texture_id~,
    environment_map_intensity~,
    environment_map_rotation~,
    point_shadow_near~,
    pass_kind~,
    clear_enabled~,
  )
}

///|
fn render3d_build_mesh_gpu_draw_payload(
  mesh_id : Int,
  preprocess_camera_key_hi : Int,
  preprocess_camera_key_lo : Int,
  draw_storage_index : Int,
  indirect_kind : Int,
  indirect_parameters_index : Int,
  material : StandardMaterial,
  transform : @transform.Transform,
  previous_transform : @transform.Transform,
  draw_color_r : Float,
  draw_color_g : Float,
  draw_color_b : Float,
  draw_alpha : Float,
  texture_id : Int,
  normal_texture_id : Int,
  emissive_texture_id : Int,
  metallic_roughness_texture_id : Int,
  occlusion_texture_id : Int,
  depth_texture_id : Int,
  anisotropy_texture_id : Int,
  specular_tint_texture_id : Int,
  draw_surface_roughness : Float,
  draw_reflectance : Float,
  draw_diffuse_transmission : Float,
  draw_specular_transmission : Float,
  draw_thickness : Float,
  draw_ior : Float,
  transmission_source_texture_id : Int,
  transmission_blur_taps : Float,
  transmission_steps : Float,
  point_shadow_texture_id : Int,
  point_shadow_enabled : Float,
  point_shadow_depth_bias : Float,
  environment_diffuse_texture_id : Int,
  environment_specular_texture_id : Int,
  environment_map_intensity : Float,
  environment_map_rotation : @math.Quat,
  specular_tint : @sprite.Color,
  anisotropy_strength : Float,
  max_relief_mapping_search_steps : Float,
  draw_flags : Int,
  shader_path? : String? = None,
  skinning_key_hi? : Int = -1,
  skinning_key_lo? : Int = -1,
) -> MeshGpuDrawPayload3d {
  @pbr_render.render3d_build_mesh_gpu_draw_payload(
    mesh_id,
    preprocess_camera_key_hi,
    preprocess_camera_key_lo,
    draw_storage_index,
    indirect_kind,
    indirect_parameters_index,
    material,
    transform,
    previous_transform,
    draw_color_r,
    draw_color_g,
    draw_color_b,
    draw_alpha,
    texture_id,
    normal_texture_id,
    emissive_texture_id,
    metallic_roughness_texture_id,
    occlusion_texture_id,
    depth_texture_id,
    anisotropy_texture_id,
    specular_tint_texture_id,
    draw_surface_roughness,
    draw_reflectance,
    draw_diffuse_transmission,
    draw_specular_transmission,
    draw_thickness,
    draw_ior,
    transmission_source_texture_id,
    transmission_blur_taps,
    transmission_steps,
    point_shadow_texture_id,
    point_shadow_enabled,
    point_shadow_depth_bias,
    environment_diffuse_texture_id,
    environment_specular_texture_id,
    environment_map_intensity,
    environment_map_rotation,
    specular_tint,
    anisotropy_strength,
    max_relief_mapping_search_steps,
    draw_flags,
    shader_path~,
    skinning_key_hi~,
    skinning_key_lo~,
  )
}

///|
fn render3d_draw_mesh_gpu_payload(payload : MeshGpuDrawPayload3d) -> Unit {
  @pbr_render.render3d_draw_mesh_gpu_payload(payload)
}
