import {
  "Milky2018/mgstudio/core",
  "Milky2018/mgstudio/ecs",
  "moonbitlang/core/json",
  "Milky2018/mgstudio/naga_oil" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_transmission_wgsl_source",
      "input": "transmission.wgsl",
      "output": "embedded_wgsl_transmission_wgsl.mbt",
    },
  ],
)
