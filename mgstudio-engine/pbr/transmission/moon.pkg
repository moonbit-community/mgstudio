import {
  "Milky2018/mgstudio/core",
  "Milky2018/mgstudio/ecs",
  "moonbitlang/core/json",
  "Milky2018/mgstudio/asset" @asset,
  "Milky2018/mgstudio/shader/wgsl_registry" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name transmission_wgsl_source",
      "input": "transmission.wgsl",
      "output": "transmission_wgsl.mbt",
    },
  ],
)
