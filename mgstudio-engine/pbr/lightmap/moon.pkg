import {
  "moonbitlang/core/json",
  "Milky2018/mgstudio/app",
  "Milky2018/mgstudio/asset",
  "Milky2018/mgstudio/core",
  "Milky2018/mgstudio/ecs",
  "Milky2018/mgstudio/math",
  "Milky2018/mgstudio/shader/wgsl_registry" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name lightmap_wgsl_source",
      "input": "lightmap.wgsl",
      "output": "lightmap_wgsl.mbt",
    },
  ],
)
