import {
  "Milky2018/mgstudio/ecs",
  "Milky2018/mgstudio/sprite",
  "Milky2018/mgstudio/sprite_render",
  "Milky2018/mgstudio/transform",
  "Milky2018/moon_wgsl" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_tilemap_chunk_material_wgsl_source",
      "input": "tilemap_chunk_material.wgsl",
      "output": "embedded_wgsl_tilemap_chunk_material_wgsl.mbt",
    },
  ],
)
