import {
  "Milky2018/mgstudio/app" @app,
  "Milky2018/mgstudio/ecs" @ecs,
  "Milky2018/mgstudio/asset" @asset,
  "Milky2018/mgstudio/shader/wgsl_registry" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name oit_resolve_wgsl_source",
      "input": "oit_resolve.wgsl",
      "output": "oit_resolve_wgsl.mbt",
    },
  ],
)
