import {
  "Milky2018/mgstudio/app" @app,
  "Milky2018/mgstudio/ecs" @ecs,
  "Milky2018/moon_wgsl" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_fullscreen_wgsl_source",
      "input": "fullscreen.wgsl",
      "output": "embedded_wgsl_fullscreen_wgsl.mbt",
    },
  ],
)
