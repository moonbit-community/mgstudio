import {
  "Milky2018/mgstudio/shader/wgsl_registry" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name fullscreen_wgsl_source",
      "input": "../fullscreen.wgsl",
      "output": "fullscreen_wgsl.mbt",
    },
  ],
)
