import {
  "Milky2018/mgstudio/app" @app,
  "Milky2018/mgstudio/ecs" @ecs,
  "Milky2018/mgstudio/naga_oil" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_downsample_depth_wgsl_source",
      "input": "downsample_depth.wgsl",
      "output": "embedded_wgsl_downsample_depth_wgsl.mbt",
    },
  ],
)
