import {
  "Milky2018/mgstudio/app" @app,
  "Milky2018/mgstudio/ecs" @ecs,
  "moonbitlang/core/json",
  "Milky2018/mgstudio/asset" @asset,
  "Milky2018/moon_wgsl" @wgsl,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name copy_deferred_lighting_id_wgsl_source",
      "input": "copy_deferred_lighting_id.wgsl",
      "output": "copy_deferred_lighting_id_wgsl.mbt",
    },
  ],
)
