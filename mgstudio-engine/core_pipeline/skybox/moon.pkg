import {
  "Milky2018/mgstudio/app" @app,
  "Milky2018/mgstudio/ecs" @ecs,
  "moonbitlang/core/json",
  "Milky2018/mgstudio/asset" @asset,
  "Milky2018/mgstudio/shader/source" @shader_source,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name skybox_prepass_wgsl_source",
      "input": "skybox_prepass.wgsl",
      "output": "skybox_prepass_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name skybox_wgsl_source",
      "input": "skybox.wgsl",
      "output": "skybox_wgsl.mbt",
    },
  ],
)
