import {
  "Milky2018/mgstudio/app",
  "Milky2018/mgstudio/ecs",
  "Milky2018/mgstudio/render" @render,
  "Milky2018/mgstudio/naga_oil" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh_preprocess_types_wgsl_source",
      "input": "mesh_preprocess_types.wgsl",
      "output": "embedded_wgsl_mesh_preprocess_types_wgsl.mbt",
    },
  ],
)
