import {
  "Milky2018/mgstudio/render/renderer" @renderer,
  "Milky2018/mgstudio/shader/source" @shader_source,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name screenshot_wgsl_source",
      "input": "screenshot.wgsl",
      "output": "screenshot_wgsl.mbt",
    },
  ],
)
