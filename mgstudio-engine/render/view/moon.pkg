import {
  "Milky2018/mgstudio/core_pipeline" @core_pipeline,
  "Milky2018/mgstudio/visibility" @visibility,
  "Milky2018/moon_wgsl" @naga_oil,
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_view_wgsl_source",
      "input": "view.wgsl",
      "output": "embedded_wgsl_view_wgsl.mbt",
    },
  ],
)
