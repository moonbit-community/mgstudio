///|
pub fn GpuBackend::new(
  assets_base? : String = "",
) -> GpuBackend raise GpuBackendError {
  let instance = @wgpu.Instance::create() catch {
    err => fatal("wgpu: Instance::create failed: \{err.message()}")
  }
  let adapter = instance.request_adapter_sync() catch {
    err =>
      fatal("wgpu: Instance::request_adapter_sync failed: \{err.message()}")
  }
  let required_features : Array[UInt] = []
  if adapter.supported_features_contains_u32(
      @wgpu.FEATURE_NAME_TEXTURE_COMPRESSION_ASTC,
    ) {
    required_features.push(@wgpu.FEATURE_NAME_TEXTURE_COMPRESSION_ASTC)
  }
  if adapter.supported_features_contains_u32(
      @wgpu.FEATURE_NAME_TEXTURE_COMPRESSION_BC,
    ) {
    required_features.push(@wgpu.FEATURE_NAME_TEXTURE_COMPRESSION_BC)
  }
  if adapter.supported_features_contains_u32(
      @wgpu.FEATURE_NAME_TEXTURE_COMPRESSION_ETC2,
    ) {
    required_features.push(@wgpu.FEATURE_NAME_TEXTURE_COMPRESSION_ETC2)
  }
  if adapter.supports_known_rust_features_u64(@wgpu.FEATURES_DEPTH_CLIP_CONTROL) {
    required_features.push(@wgpu.FEATURE_NAME_DEPTH_CLIP_CONTROL)
  }
  if adapter.supports_known_rust_features_u64(@wgpu.FEATURES_SHADER_INT64) {
    required_features.push(@wgpu.NATIVE_FEATURE_SHADER_INT64)
  }
  if adapter.supports_known_rust_features_u64(@wgpu.FEATURES_SUBGROUP) {
    required_features.push(@wgpu.NATIVE_FEATURE_SUBGROUP)
  }
  if adapter.has_feature_native_subgroup_barrier() {
    required_features.push(@wgpu.NATIVE_FEATURE_SUBGROUP_BARRIER)
  }
  if adapter.supported_features_contains_u32(
      @wgpu.FEATURE_NAME_INDIRECT_FIRST_INSTANCE,
    ) {
    required_features.push(@wgpu.FEATURE_NAME_INDIRECT_FIRST_INSTANCE)
  }
  if adapter.supported_features_contains_u32(
      @wgpu.FEATURE_NAME_RG11_B10_UFLOAT_RENDERABLE,
    ) {
    required_features.push(@wgpu.FEATURE_NAME_RG11_B10_UFLOAT_RENDERABLE)
  }
  if adapter.has_feature_native_polygon_mode_line() {
    required_features.push(@wgpu.NATIVE_FEATURE_POLYGON_MODE_LINE)
  }
  if adapter.has_feature_native_vertex_writable_storage() {
    required_features.push(@wgpu.NATIVE_FEATURE_VERTEX_WRITABLE_STORAGE)
  }
  if adapter.has_feature_native_immediates() {
    required_features.push(@wgpu.NATIVE_FEATURE_IMMEDIATES)
  }
  let device = adapter.request_device_sync_with_features_and_limits(
    instance, required_features,
  ) catch {
    err => fatal("wgpu: Adapter::request_device_sync failed: \{err.message()}")
  }
  if @sys.get_env_var("MGSTUDIO_WGPU_UNCAPTURED_ERROR_STDERR") is Some(flag) &&
    flag == "1" {
    @wgpu.set_uncaptured_error_stderr_enabled(true)
  }
  let queue = device.queue()
  GpuBackend::{
    instance,
    adapter,
    device,
    queue,
    assets_base,
    surface: None,
    surface_format: None,
    configured_width: 0,
    configured_height: 0,
    surface_capture_active: false,
    surface_cleared_this_frame: false,
    frame: None,
    pass_state: None,
    pass_has_depth: false,
    frame_count: 0U,
    depth_texture: None,
    depth_view: None,
    depth_target_id: -2,
    depth_width: 0,
    depth_height: 0,
    sprite_bgl_tex: None,
    sprite_bgl_globals: None,
    sprite_pipeline_layout: None,
    sprite_pipeline: None,
    sprite_pipeline_surface: None,
    sprite_pipeline_surface_format: None,
    sprite_pipeline_depth: None,
    sprite_pipeline_depth_surface: None,
    sprite_pipeline_depth_surface_format: None,
    sprite_globals_buf: None,
    sprite_instance_buf: None,
    sprite_index_buf: None,
    sprite_instance_capacity: 0UL,
    sprite_globals_bg: None,
    sprite_view_bgl: None,
    sprite_texture_bgl: None,
    sprite_render_pipeline_layout: None,
    sprite_view_buf: None,
    sprite_view_bg: None,
    sprite_lut_texture: None,
    sprite_lut_view: None,
    sprite_lut_sampler: None,
    sprite_instance_data: [],
    sprite_batches: [],
    sprite_instance_count: 0U,
    ui_view_bgl: None,
    ui_pipeline_layout: None,
    ui_pipeline: None,
    ui_pipeline_anti_alias: None,
    ui_pipeline_surface: None,
    ui_pipeline_surface_anti_alias: None,
    ui_pipeline_surface_format: None,
    ui_view_buf: None,
    ui_view_bg: None,
    ui_vertex_buf: None,
    ui_vertex_capacity: 0UL,
    ui_vertex_data: [],
    ui_batches: [],
    ui_vertex_count: 0U,
    ui_shadow_view_bgl: None,
    ui_shadow_pipeline_layout: None,
    ui_shadow_view_buf: None,
    ui_shadow_view_bg: None,
    ui_shadow_vertex_buf: None,
    ui_shadow_vertex_capacity: 0UL,
    ui_shadow_vertex_data: [],
    ui_shadow_batches: [],
    ui_shadow_pipeline_cache: [],
    ui_shadow_vertex_count: 0U,
    ui_slice_view_bgl: None,
    ui_slice_pipeline_layout: None,
    ui_slice_pipeline: None,
    ui_slice_pipeline_surface: None,
    ui_slice_pipeline_surface_format: None,
    ui_slice_view_buf: None,
    ui_slice_globals_buf: None,
    ui_slice_view_bg: None,
    ui_slice_vertex_buf: None,
    ui_slice_vertex_capacity: 0UL,
    ui_slice_vertex_data: [],
    ui_slice_batches: [],
    ui_slice_vertex_count: 0U,
    mesh_pipeline_layout: None,
    mesh_pipeline: None,
    mesh_pipeline_surface: None,
