    mesh3d_pipeline_surface_line_list: None,
    mesh3d_pipeline_surface_line_list_transparent: None,
    mesh3d_pipeline_surface_line_strip: None,
    mesh3d_pipeline_surface_line_strip_transparent: None,
    mesh3d_pipeline_surface_format: None,
    mesh3d_pipeline_rgba8_cull_mode: -1,
    mesh3d_pipeline_surface_cull_mode: -1,
    mesh3d_custom_pipeline_cache: [],
    mesh3d_point_shadow_compare_sampler: None,
    mesh3d_view_buf: None,
    mesh3d_pass_view_uniform_bytes: None,
    mesh3d_pass_view_uniform_frame_count: 0U,
    mesh3d_pass_view_uniform_camera_key_hi: -1,
    mesh3d_pass_view_uniform_camera_key_lo: -1,
    mesh3d_pass_view_uniform_pass_kind: -1,
    mesh3d_motion_vector_pass_view_uniform_bytes: None,
    mesh3d_motion_vector_pass_previous_view_uniform_bytes: None,
    mesh3d_draw_slots: [],
    mesh3d_draw_slot_used: 0,
    mesh3d_skin_current_buf: None,
    mesh3d_skin_current_bg: None,
    mesh3d_skin_prev_buf: None,
    mesh3d_skin_prev_bg: None,
    mesh3d_skin_capacity: 0UL,
    mesh3d_skin_staging_bytes: [],
    mesh3d_skin_staging_view: [],
    mesh3d_skin_revision: 0,
    mesh3d_gpu_instance_builder_enabled: false,
    mesh3d_instance_draw_buf: None,
    mesh3d_instance_draw_bg: None,
    mesh3d_instance_draw_capacity: 0UL,
