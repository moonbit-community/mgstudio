import {
  "Milky2018/mgstudio/app",
  "Milky2018/mgstudio/asset",
  "Milky2018/mgstudio/ecs",
  "Milky2018/mgstudio/input",
  "Milky2018/mgstudio/math",
  "Milky2018/mgstudio/mesh",
  "Milky2018/mgstudio/post_process",
  "Milky2018/mgstudio/render",
  "Milky2018/moon_wgsl" @naga_oil,
  "Milky2018/mgstudio/shader",
  "Milky2018/mgstudio/time",
  "Milky2018/mgstudio/visibility",
  "Milky2018/mgstudio/window",
  "moonbitlang/core/hashmap",
  "moonbitlang/core/json",
  "moonbitlang/core/ref",
  "tonyfettes/any",
  "Milky2018/mgstudio/core",
  "Milky2018/mgstudio/color",
  "Milky2018/mgstudio/core_pipeline",
  "Milky2018/mgstudio/transform",
}

supported_targets = "native"

options(
  "pre-build": [
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_color_material_wgsl_source",
      "input": "../sprite_render/mesh2d/color_material.wgsl",
      "output": "embedded_wgsl_mesh2d_color_material_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_bindings_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d_bindings.wgsl",
      "output": "embedded_wgsl_mesh2d_bindings_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_functions_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d_functions.wgsl",
      "output": "embedded_wgsl_mesh2d_functions_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_types_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d_types.wgsl",
      "output": "embedded_wgsl_mesh2d_types_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_vertex_output_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d_vertex_output.wgsl",
      "output": "embedded_wgsl_mesh2d_vertex_output_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_view_bindings_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d_view_bindings.wgsl",
      "output": "embedded_wgsl_mesh2d_view_bindings_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_view_types_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d_view_types.wgsl",
      "output": "embedded_wgsl_mesh2d_view_types_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_mesh2d_wgsl_source",
      "input": "../sprite_render/mesh2d/mesh2d.wgsl",
      "output": "embedded_wgsl_mesh2d_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_wireframe2d_wgsl_source",
      "input": "../sprite_render/mesh2d/wireframe2d.wgsl",
      "output": "embedded_wgsl_wireframe2d_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_sprite_render_sprite_wgsl_source",
      "input": "../sprite_render/render/sprite.wgsl",
      "output": "embedded_wgsl_sprite_render_sprite_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_sprite_render_sprite_view_bindings_wgsl_source",
      "input": "../sprite_render/render/sprite_view_bindings.wgsl",
      "output": "embedded_wgsl_sprite_render_sprite_view_bindings_wgsl.mbt",
    },
    {
      "command": ":embed --input $input --output $output --name embedded_wgsl_shaders_custom_mesh2d_checker_material_wgsl_source",
      "input": "../assets/shaders/mesh2d_checker_material.wgsl",
      "output": "embedded_wgsl_shaders_custom_mesh2d_checker_material_wgsl.mbt",
    },
  ],
)
